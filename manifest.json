{
    "manifest_version": 3,
    "name": "Stickify",
    "version": "1.2.0",
    "description": "A beautiful, simple, and feature-rich sticky notes companion for your browser...",
    "permissions": [
      "sidePanel",
      "storage"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "action": {
      "default_title": "Open Sticky Notes"
    },
    "background": {
      "service_worker": "background.js"
    },
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    }
  }